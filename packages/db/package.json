{
  "name": "@repo/db",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./migrations": "./dist/migrations.js",
    "./utils": "./dist/utils.js",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "clean": "rimraf .turbo node_modules dist",
    "db:schema": "drizzle-kit generate --config drizzle.config.ts",
    "db:schema:postgres": "drizzle-kit generate --config drizzle.config.postgres.ts",
    "db:migrate": "tsx src/migrate.ts",
    "db:migrate:postgres": "tsx src/migrate-postgres.ts",
    "db:dump:local-to-turso": "tsx src/scripts/dump-local-to-turso.ts",
    "db:dump:local-to-postgres": "tsx src/scripts/dump-local-to-postgres.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@libsql/client": "0.15.15",
    "@repo/dates": "workspace:*",
    "@repo/types": "workspace:*",
    "drizzle-orm": "0.44.7",
    "p-map": "7.0.3",
    "pg": "^8.20.0",
    "uuidv7": "1.0.2"
  },
  "devDependencies": {
    "@faker-js/faker": "9.6.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "22.12.0",
    "@types/pg": "^8.20.0",
    "dotenv": "16.4.7",
    "drizzle-kit": "0.31.6",
    "fs-extra": "11.3.0",
    "rimraf": "6.0.1",
    "tsup": "8.4.0",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "3.0.8"
  }
}
